generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User & Role Management
enum UserRole {
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum TaxType {
  PPH21
  PPH23
  PPN
}

enum TaxSourceType {
  TRANSACTION
  PAYROLL
  MANUAL
}

enum WorkOrderCostType {
  LABOR
  OVERHEAD
  MACHINE
  SUBCONTRACT
  WASTE
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  password             String // Hashed password
  name                 String
  phone                String?
  avatar               String? // URL avatar
  role                 UserRole  @default(STAFF)
  permissions          String[]  @default([])
  isPlatformAdmin      Boolean   @default(false)
  organizationId       String?
  status               String    @default("ACTIVE") // ACTIVE, INACTIVE, PENDING
  inviteToken          String?   @unique
  inviteTokenExpiresAt DateTime?
  resetToken           String?   @unique
  resetTokenExpiresAt  DateTime?
  passwordSetAt        DateTime?
  lastLogin            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization          Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  auditLogs             AuditLog[]        @relation("UserAuditLog")
  pettyCashCustody      PettyCash[]       @relation("PettyCashCustodian")
  workOrdersAssigned    WorkOrder[]       @relation("WorkOrderAssignee")
  warehousesManaged     Warehouse[]       @relation("WarehouseManager")
  salesOrdersAssigned   SalesOrder[]      @relation("SalesPerson")
  commissionsReceived   SalesCommission[] @relation("CommissionSalesPerson")
  branchesManaged       Branch[]          @relation("BranchManager")
  stockOpnamesPerformed StockOpname[]     @relation("StockOpnamePerformer")
  stockOpnamesApproved  StockOpname[]     @relation("StockOpnameApprover")
  budgetsApproved       Budget[]          @relation("BudgetApprover")
  division              Division?         @relation("DivisionManager")
}

// 1. Tabel Organisasi (Multitenant)
model Organization {
  id                   String    @id @default(uuid())
  name                 String
  type                 String // YAYASAN atau PERUSAHAAN
  address              String? // Alamat
  city                 String? // Kota
  province             String? // Provinsi
  postalCode           String? // Kode Pos
  phone                String? // Nomor Telepon
  email                String? // Email
  logo                 String? // URL Logo
  taxId                String? // NPWP
  registrationNumber   String? // Nomor Pendaftaran (Akta Notaris / SK Kemenkumham)
  currency             String    @default("IDR") // Mata uang
  fiscalYearStart      Int       @default(1) // Bulan awal tahun fiskal (1-12)
  status               String    @default("ACTIVE") // ACTIVE, INACTIVE
  subscriptionPlan     String    @default("ANNUAL")
  subscriptionStatus   String    @default("ACTIVE") // ACTIVE, EXPIRED, SUSPENDED
  subscriptionStartsAt DateTime?
  subscriptionEndsAt   DateTime?
  maxUsers             Int       @default(5)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relasi ke tabel lain
  accounts              ChartOfAccount[]
  categories            AccountCategory[]
  banks                 BankAccount[]
  investments           Investment[]
  transactions          Transaction[]
  employees             Employee[]
  salarySlips           SalarySlip[]
  taxEntries            TaxEntry[]
  auditLogs             AuditLog[]
  noteSequences         NoteSequence[]
  users                 User[]
  subscriptionPayments  SubscriptionPayment[]
  periodLocks           PeriodLock[]
  customers             Customer[]
  suppliers             Supplier[]
  invoices              Invoice[]
  vendorBills           VendorBill[]
  invoicePayments       InvoicePayment[]
  vendorBillPayments    VendorBillPayment[]
  purchaseOrders        PurchaseOrder[]
  bankReconciliations   BankReconciliation[]   @relation("BankReconciliations")
  boms                  BillOfMaterial[]
  workOrders            WorkOrder[]
  warehouses            Warehouse[]
  inventoryItems        InventoryItem[]
  inventoryMovements    InventoryMovement[]
  stockOpnames          StockOpname[]
  salesOrders           SalesOrder[]
  deliveryOrders        DeliveryOrder[]
  salesCommissions      SalesCommission[]
  recurringTransactions RecurringTransaction[] @relation("RecurringTransactions")
  currencies            Currency[]
  exchangeRates         ExchangeRate[]
  pettyCashAccounts     PettyCash[]
  branches              Branch[]
  budgets               Budget[]
  divisions             Division[]
  attendanceRecords     AttendanceRecord[]
  facilityMaintenances  FacilityMaintenance[]
 inventoryAccountingConfig InventoryAccountingConfig?
}

// Paket berlangganan (dikelola platform admin)
model SubscriptionPackage {
  id             String   @id @default(uuid())
  code           String   @unique // contoh: MONTHLY, ANNUAL, atau kode custom
  name           String
  durationMonths Int?
  amountIdr      Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
}

// 2. Tabel Kategori Akun
model AccountCategory {
  id             String @id @default(uuid())
  organizationId String
  name           String // Contoh: Gaji, Bonus, Uang Makan, dll
  color          String @default("#3B82F6")

  organization Organization     @relation(fields: [organizationId], references: [id])
  accounts     ChartOfAccount[]
}

// 3. Tabel Daftar Akun (COA)
model ChartOfAccount {
  id             String  @id @default(uuid())
  organizationId String
  categoryId     String? // Relasi ke AccountCategory
  code           String
  name           String
  type           String // Asset, Liability, Equity, Revenue, Expense
  isHeader       Boolean @default(false)

  organization         Organization      @relation(fields: [organizationId], references: [id])
  category             AccountCategory?  @relation(fields: [categoryId], references: [id])
  bankAccount          BankAccount? // Relasi 1-to-1: 1 Akun bisa jadi 1 Rekening Bank
  investment           Investment? // Relasi 1-to-1: 1 Akun bisa jadi 1 investasi
  journalItems         TransactionLine[]
  budgetItemsAsAccount BudgetItem[]      @relation("BudgetItemAccount")
  configAsInventory         InventoryAccountingConfig[] @relation("ConfigInventoryAccount")
  configAsWip               InventoryAccountingConfig[] @relation("ConfigWipAccount")
  configAsFinishedGoods     InventoryAccountingConfig[] @relation("ConfigFinishedGoodsAccount")
  configAsVariance          InventoryAccountingConfig[] @relation("ConfigVarianceAccount")
  configAsCogs              InventoryAccountingConfig[] @relation("ConfigCogsAccount")
}

// 4. Tabel Rekening Bank (Buku Pembantu Bank)
model BankAccount {
  id             String   @id @default(uuid())
  organizationId String
  accountId      String   @unique // Terhubung langsung ke ChartOfAccount
  bankName       String // Contoh: BCA, Mandiri, BSI
  accountNumber  String // Nomor Rekening
  accountName    String // Atas Nama
  balance        Float    @default(0) // Saldo Rekening
  currencyId     String?
  status         String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization          Organization         @relation(fields: [organizationId], references: [id])
  account               ChartOfAccount       @relation(fields: [accountId], references: [id])
  currency              Currency?            @relation(fields: [currencyId], references: [id])
  sourceInvestments     Investment[]         @relation("InvestmentSourceBank")
  settlementInvestments Investment[]         @relation("InvestmentSettlementBank")
  reconciliations       BankReconciliation[] @relation("BankReconciliations")
}

model Investment {
  id                      String    @id @default(uuid())
  organizationId          String
  accountId               String    @unique
  sourceBankAccountId     String?
  settlementBankAccountId String?
  inkasoTransactionId     String?   @unique
  type                    String // DEPOSITO, SAHAM, INVESTASI_LAINNYA
  name                    String
  institution             String
  referenceNumber         String?
  startDate               DateTime
  maturityDate            DateTime?
  purchaseAmount          Float
  currentValue            Float
  expectedReturn          Float     @default(0)
  status                  String    @default("ACTIVE") // ACTIVE, MATURED, LIQUIDATED
  notes                   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  organization          Organization   @relation(fields: [organizationId], references: [id])
  account               ChartOfAccount @relation(fields: [accountId], references: [id])
  sourceBankAccount     BankAccount?   @relation("InvestmentSourceBank", fields: [sourceBankAccountId], references: [id])
  settlementBankAccount BankAccount?   @relation("InvestmentSettlementBank", fields: [settlementBankAccountId], references: [id])
  inkasoTransaction     Transaction?   @relation("InvestmentInkasoTransaction", fields: [inkasoTransactionId], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, type])
}

// 4. Tabel Header Transaksi (Nota/Jurnal)
model Transaction {
  id                     String   @id @default(uuid())
  organizationId         String
  date                   DateTime @default(now())
  description            String // Keterangan transaksi (misal: "Bayar Listrik Bulan April")
  reference              String? // Nomor Nota / Invoice (bisa untuk PDF/WA)
  createdAt              DateTime @default(now())
  recurringTransactionId String? // Referensi ke recurring transaction yang generate transaksi ini

  organization         Organization            @relation(fields: [organizationId], references: [id])
  lines                TransactionLine[]
  taxEntries           TaxEntry[]
  investmentInkaso     Investment?             @relation("InvestmentInkasoTransaction")
  attachments          TransactionAttachment[]
  recurringTransaction RecurringTransaction?   @relation("RecurringSource", fields: [recurringTransactionId], references: [id])
}

// 5. Tabel Detail Transaksi (Debit & Kredit)
model TransactionLine {
  id            String  @id @default(uuid())
  transactionId String
  accountId     String
  debit         Float   @default(0)
  credit        Float   @default(0)
  description   String? // Keterangan tambahan

  // Cascade: Jika Transaksi dihapus, baris detailnya ikut terhapus
  transaction Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account     ChartOfAccount @relation(fields: [accountId], references: [id])
}

// 6. Tabel Karyawan
model Employee {
  id                  String    @id @default(uuid())
  organizationId      String
  name                String // Nama lengkap
  nik                 String? // Nomor Induk Karyawan
  employeeNumber      String? // Nomor Pegawai (bisa sama dengan NIK)
  email               String?
  phone               String?
  identityNumber      String? // KTP/SIM/Paspor
  identityType        String? // Type: KTP, SIM, Paspor
  taxFileNumber       String? // NPWP
  bankAccount         String? // Nomor rekening untuk giro
  bankName            String? // Nama bank
  position            String // Jabatan
  department          String? // Departemen
  joinDate            DateTime // Tanggal bergabung
  exitDate            DateTime? // Tanggal keluar (null jika masih aktif)
  baseSalary          Float // Gaji pokok
  taxStatus           String    @default("TK") // Status pajak: TK, K, K1, K2, K3
  bpjsKesehatanNumber String? // Nomor BPJS Kesehatan
  bpjsKetenagakerjaan String? // Nomor BPJS Ketenagakerjaan
  status              String    @default("ACTIVE") // ACTIVE, INACTIVE, LEAVE
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  salarySlips  SalarySlip[]
  allowances   Allowance[]
  deductions   Deduction[]
  attendanceRecords AttendanceRecord[]
}

// 7. Tabel Tunjangan (Allowances)
model Allowance {
  id            String    @id @default(uuid())
  employeeId    String
  name          String // Nama tunjangan: Tunjangan Transport, Tunjangan Makan, dll
  amount        Float // Nominal tunjangan
  effectiveDate DateTime // Mulai berlaku
  endDate       DateTime? // Berakhir (null jika permanent)
  isTaxable     Boolean   @default(true) // Apakah kena pajak
  createdAt     DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// 8. Tabel Potongan (Deductions)
model Deduction {
  id            String    @id @default(uuid())
  employeeId    String
  name          String // Nama potongan: Pinjaman, Cicilan, dll
  amount        Float // Nominal potongan
  effectiveDate DateTime // Mulai berlaku
  endDate       DateTime? // Berakhir (null jika permanent)
  createdAt     DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// 9. Tabel Slip Gaji
model SalarySlip {
  id                    String    @id @default(uuid())
  organizationId        String
  employeeId            String
  month                 Int // Bulan (1-12)
  year                  Int // Tahun
  baseSalary            Float
  totalAllowance        Float     @default(0)
  totalDeduction        Float     @default(0)
  bpjsKesehatanEmployee Float     @default(0) // 4%
  bpjsKetenagakerjaan   Float     @default(0) // 2%
  pph21                 Float     @default(0) // PPh 21
  grossIncome           Float // Gaji Bruto = Gaji Pokok + Tunjangan
  netIncome             Float // Gaji Netto = Gross - Semua Potongan
  status                String    @default("DRAFT") // DRAFT, FINALIZED, PAID, CANCELLED
  paymentDate           DateTime? // Tanggal pembayaran
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  taxEntries   TaxEntry[]

  // Unique constraint: 1 karyawan hanya bisa punya 1 slip per bulan
  @@unique([employeeId, month, year])
}

// Absensi (Time & Attendance) - dasar untuk lembur & payroll
model AttendanceRecord {
  id             String   @id @default(uuid())
  organizationId String
  employeeId     String
  date           DateTime
  checkInAt      DateTime?
  checkOutAt     DateTime?
  overtimeMinutes Int     @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([organizationId, date])
  @@index([employeeId, date])
}

// Jadwal maintenance fasilitas/GA (kendaraan, gedung, dll)
model FacilityMaintenance {
  id             String   @id @default(uuid())
  organizationId String
  assetName      String
  assetCategory  String? // kendaraan, gedung, dll
  scheduledAt    DateTime
  completedAt    DateTime?
  status         String   @default("PLANNED") // PLANNED, DONE, CANCELLED
  estimatedCost  Float    @default(0)
  actualCost     Float    @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, scheduledAt])
  @@index([status])
}

model TaxEntry {
  id             String        @id @default(uuid())
  organizationId String
  transactionId  String?
  salarySlipId   String?
  sourceType     TaxSourceType
  taxType        TaxType
  date           DateTime      @default(now())
  periodMonth    Int
  periodYear     Int
  taxBase        Float         @default(0)
  taxAmount      Float
  reference      String?
  description    String
  counterparty   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction  Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  salarySlip   SalarySlip?  @relation(fields: [salarySlipId], references: [id], onDelete: Cascade)

  @@index([organizationId, periodYear, periodMonth])
  @@index([taxType, periodYear, periodMonth])
  @@index([transactionId])
  @@index([salarySlipId])
}

// 10. Tabel Audit Logs (Keamanan & Audit Trail)
model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?
  userId         String? // ID user yang melakukan perubahan
  action         String // CREATE, UPDATE, DELETE, READ, EXPORT
  entity         String // Nama tabel yang diubah: Transaction, Employee, SalarySlip, dll
  entityId       String // ID record yang diubah
  userName       String? // Nama user
  userEmail      String? // Email user
  oldData        String? // Data sebelum perubahan (JSON)
  newData        String? // Data setelah perubahan (JSON)
  changes        String? // Summary perubahan spesifik (JSON)
  reason         String? // Alasan perubahan
  ipAddress      String? // IP address user
  userAgent      String? // User agent browser
  timestamp      DateTime @default(now())
  status         String   @default("SUCCESS") // SUCCESS, FAILED
  errorMessage   String? // Pesan error jika gagal

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation("UserAuditLog", fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([timestamp])
}

// 11. Tabel Sequence Nota (untuk auto-increment nota)
model NoteSequence {
  id             String   @id @default(uuid())
  organizationId String
  code           String // Kode nota: BKK, BKM, BMP, dll
  year           Int // Tahun
  sequence       Int      @default(0) // Urutan nota tahun ini
  prefix         String? // Prefix custom (misal: "INV-")
  lastNote       String? // Nomor nota terakhir yang digunakan
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code, year])
  @@index([organizationId])
}

model SubscriptionPayment {
  id             String    @id @default(uuid())
  organizationId String
  orderId        String    @unique
  provider       String    @default("MIDTRANS")
  plan           String    @default("ANNUAL")
  years          Int       @default(1)
  amount         Float
  currency       String    @default("IDR")
  status         String    @default("PENDING") // PENDING, SETTLEMENT, EXPIRE, CANCEL, DENY
  paymentType    String?
  transactionId  String?
  snapToken      String?
  redirectUrl    String?
  paidAt         DateTime?
  expiresAt      DateTime?
  lastPayload    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([orderId])
}

// 12. Period Lock - Tutup Buku
model PeriodLock {
  id             String    @id @default(uuid())
  organizationId String
  year           Int
  month          Int // NULL untuk lock seluruh tahun
  lockType       String    @default("PERIOD") // PERIOD, YEAR, FULL
  lockedAt       DateTime  @default(now())
  lockedBy       String // User ID
  lockedByName   String? // User name untuk reference
  reason         String?
  isLocked       Boolean   @default(true)
  unlockedAt     DateTime?
  unlockedBy     String? // User ID
  unlockedByName String?
  unlockReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, year, month])
  @@index([organizationId, year])
  @@index([organizationId, isLocked])
}

// 13. AR/AP - Customer (Account Receivable)
model Customer {
  id             String   @id @default(uuid())
  organizationId String
  code           String // Kode customer: CUST-001
  name           String // Nama customer
  contactPerson  String? // Nama kontak person
  email          String?
  phone          String?
  mobile         String? // Nomor HP
  address        String?
  city           String?
  province       String?
  postalCode     String?
  country        String?  @default("Indonesia")
  npwp           String? // NPWP untuk faktur pajak
  creditLimit    Float    @default(0) // Limit kredit
  paymentTerm    Int      @default(30) // Term pembayaran (hari)
  status         String   @default("ACTIVE") // ACTIVE, INACTIVE
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  workOrders     WorkOrder[]
  salesOrders    SalesOrder[]
  deliveryOrders DeliveryOrder[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
}

// 14. AR/AP - Supplier (Account Payable)
model Supplier {
  id             String   @id @default(uuid())
  organizationId String
  code           String // Kode supplier: SUPP-001
  name           String // Nama supplier
  contactPerson  String? // Nama kontak person
  email          String?
  phone          String?
  mobile         String? // Nomor HP
  address        String?
  city           String?
  province       String?
  postalCode     String?
  country        String?  @default("Indonesia")
  npwp           String? // NPWP untuk faktur pajak
  bankAccount    String? // Nomor rekening untuk pembayaran
  bankName       String? // Nama bank
  paymentTerm    Int      @default(30) // Term pembayaran (hari)
  status         String   @default("ACTIVE") // ACTIVE, INACTIVE
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendorBills    VendorBill[]
  purchaseOrders PurchaseOrder[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
}

// 15. AR/AP - Invoice (Account Receivable)
model Invoice {
  id              String   @id @default(uuid())
  organizationId  String
  customerId      String
  invoiceNumber   String // Nomor invoice: INV-2024-001
  invoiceDate     DateTime
  dueDate         DateTime
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0) // PPN
  discountAmount  Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  remainingAmount Float    @default(0)
  status          String   @default("DRAFT") // DRAFT, SENT, PARTIALLY_PAID, PAID, OVERDUE, CANCELLED
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items        InvoiceItem[]
  payments     InvoicePayment[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, customerId])
  @@index([organizationId, status])
  @@index([organizationId, invoiceDate])
}

// 16. AR/AP - Invoice Item
model InvoiceItem {
  id          String @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float  @default(1)
  unitPrice   Float
  discount    Float  @default(0)
  taxRate     Float  @default(0) // PPN rate: 11%
  subtotal    Float
  taxAmount   Float
  total       Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// 17. AR/AP - Vendor Bill (Account Payable)
model VendorBill {
  id              String   @id @default(uuid())
  organizationId  String
  supplierId      String
  billNumber      String // Nomor bill: BILL-2024-001
  billDate        DateTime
  dueDate         DateTime
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0) // PPN
  discountAmount  Float    @default(0)
  totalAmount     Float    @default(0)
  paidAmount      Float    @default(0)
  remainingAmount Float    @default(0)
  status          String   @default("DRAFT") // DRAFT, RECEIVED, PARTIALLY_PAID, PAID, OVERDUE, CANCELLED
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items        VendorBillItem[]
  payments     VendorBillPayment[]

  @@unique([organizationId, billNumber])
  @@index([organizationId, supplierId])
  @@index([organizationId, status])
  @@index([organizationId, billDate])
}

// 18. AR/AP - Vendor Bill Item
model VendorBillItem {
  id           String @id @default(uuid())
  vendorBillId String
  description  String
  quantity     Float  @default(1)
  unitPrice    Float
  discount     Float  @default(0)
  taxRate      Float  @default(0) // PPN rate: 11%
  subtotal     Float
  taxAmount    Float
  total        Float

  vendorBill VendorBill @relation(fields: [vendorBillId], references: [id], onDelete: Cascade)
}

// 19. AR/AP - Invoice Payment
model InvoicePayment {
  id              String   @id @default(uuid())
  organizationId  String
  invoiceId       String
  paymentDate     DateTime
  amount          Float
  paymentMethod   String // TRANSFER, CASH, CHECK
  bankAccountId   String?
  referenceNumber String?
  notes           String?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([organizationId, invoiceId])
  @@index([organizationId, paymentDate])
}

// 20. AR/AP - Vendor Bill Payment
model VendorBillPayment {
  id              String   @id @default(uuid())
  organizationId  String
  vendorBillId    String
  paymentDate     DateTime
  amount          Float
  paymentMethod   String // TRANSFER, CASH, CHECK
  bankAccountId   String?
  referenceNumber String?
  notes           String?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendorBill   VendorBill   @relation(fields: [vendorBillId], references: [id], onDelete: Cascade)

  @@index([organizationId, vendorBillId])
  @@index([organizationId, paymentDate])
}

// Purchase Order Model
model PurchaseOrder {
  id             String    @id @default(uuid())
  organizationId String
  supplierId     String
  poNumber       String    @unique
  orderDate      DateTime
  expectedDate   DateTime?
  status         String    @default("DRAFT") // DRAFT, SENT, RECEIVED, CANCELLED
  subtotal       Decimal   @db.Decimal(20, 2)
  taxAmount      Decimal   @default(0) @db.Decimal(20, 2)
  discountAmount Decimal   @default(0) @db.Decimal(20, 2)
  totalAmount    Decimal   @db.Decimal(20, 2)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  items        PurchaseOrderItem[]

  @@index([organizationId])
  @@index([supplierId])
  @@index([poNumber])
}

model PurchaseOrderItem {
  id              String  @id @default(uuid())
  purchaseOrderId String
  itemId          String? // Relasi ke master barang di Inventory
  description     String
  quantity        Decimal @db.Decimal(10, 2)
  receivedQty     Decimal @default(0) @db.Decimal(10, 2) // Qty yang sudah diterima (GRN)
  unitPrice       Decimal @db.Decimal(20, 2)
  discount        Decimal @default(0) @db.Decimal(20, 2)
  taxRate         Decimal @default(0) @db.Decimal(5, 2)
  subtotal        Decimal @db.Decimal(20, 2)
  taxAmount       Decimal @db.Decimal(20, 2)
  total           Decimal @db.Decimal(20, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item          InventoryItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@index([itemId])
}

// Bank Reconciliation Model
model BankReconciliation {
  id                 String    @id @default(uuid())
  organizationId     String
  bankAccountId      String
  reconciliationDate DateTime
  statementBalance   Float // Saldo dari rekening koran/bank statement
  bookBalance        Float // Saldo buku dari sistem
  difference         Float // Selisih (statementBalance - bookBalance)
  status             String    @default("PENDING") // PENDING, RECONCILED
  notes              String?
  reconciledBy       String? // User ID yang melakukan rekonsiliasi
  reconciledAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization Organization             @relation("BankReconciliations", fields: [organizationId], references: [id], onDelete: Cascade)
  bankAccount  BankAccount              @relation("BankReconciliations", fields: [bankAccountId], references: [id])
  items        BankReconciliationItem[]

  @@index([organizationId])
  @@index([bankAccountId])
  @@index([reconciliationDate])
}

model BankReconciliationItem {
  id               String   @id @default(uuid())
  reconciliationId String
  transactionId    String? // Transaction yang di-reconcile
  type             String // DEPOSIT, WITHDRAWAL, ADJUSTMENT
  amount           Float
  description      String
  isChecked        Boolean  @default(false)
  createdAt        DateTime @default(now())

  reconciliation BankReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)

  @@index([reconciliationId])
}

// Recurring Transaction Model
model RecurringTransaction {
  id             String    @id @default(uuid())
  organizationId String
  name           String // Nama recurring transaction (misal: "Sewa Kantor Bulanan")
  description    String?
  frequency      String // DAILY, WEEKLY, MONTHLY, QUARTERLY, YEARLY
  interval       Int       @default(1) // Interval (misal: setiap 2 minggu = 2)
  startDate      DateTime
  endDate        DateTime? // Null untuk ongoing
  nextRunDate    DateTime
  isActive       Boolean   @default(true)
  totalAmount    Float // Total amount untuk recurring
  notes          String?

  // Template untuk transaction lines
  lines                 RecurringTransactionLine[]
  organization          Organization               @relation("RecurringTransactions", fields: [organizationId], references: [id], onDelete: Cascade)
  generatedTransactions Transaction[]              @relation("RecurringSource")

  @@index([organizationId])
  @@index([nextRunDate])
  @@index([isActive])
}

model RecurringTransactionLine {
  id                     String  @id @default(uuid())
  recurringTransactionId String
  accountId              String
  debit                  Float   @default(0)
  credit                 Float   @default(0)
  description            String?

  recurringTransaction RecurringTransaction @relation(fields: [recurringTransactionId], references: [id], onDelete: Cascade)

  @@index([recurringTransactionId])
}

// Transaction Attachment Model
model TransactionAttachment {
  id            String   @id @default(uuid())
  transactionId String
  fileName      String
  fileUrl       String // URL file (bisa dari S3, Cloudinary, dll)
  fileSize      Int? // Ukuran file dalam bytes
  fileType      String? // MIME type (image/jpeg, application/pdf, dll)
  uploadedBy    String? // User ID yang upload
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

// Currency Model for Multi-Currency
model Currency {
  id             String   @id @default(uuid())
  organizationId String
  code           String // USD, EUR, JPY, dll
  name           String // US Dollar, Euro, Japanese Yen
  symbol         String // $, €, ¥
  isBase         Boolean  @default(false) // Mata uang dasar organisasi
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromExchangeRates ExchangeRate[] @relation("ExchangeRateFrom")
  toExchangeRates   ExchangeRate[] @relation("ExchangeRateTo")
  bankAccounts      BankAccount[]
  pettyCashAccounts PettyCash[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

// Exchange Rate Model
model ExchangeRate {
  id             String   @id @default(uuid())
  organizationId String
  fromCurrencyId String
  toCurrencyId   String
  rate           Float // Exchange rate (1 fromCurrency = X toCurrency)
  effectiveDate  DateTime @default(now())
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromCurrency Currency     @relation("ExchangeRateFrom", fields: [fromCurrencyId], references: [id])
  toCurrency   Currency     @relation("ExchangeRateTo", fields: [toCurrencyId], references: [id])

  @@unique([organizationId, fromCurrencyId, toCurrencyId, effectiveDate])
  @@index([organizationId])
  @@index([effectiveDate])
}

// Petty Cash Model
model PettyCash {
  id             String   @id @default(uuid())
  organizationId String
  name           String // Nama kas kecil (misal: "Kas Kecil Marketing")
  code           String // Kode kas kecil (misal: "KK-MKT")
  currencyId     String
  fundType       String // IMPREST atau FLUKTUASI
  initialAmount  Float    @default(0)
  currentAmount  Float    @default(0)
  custodianId    String? // User ID yang bertanggung jawab
  location       String? // Lokasi kas kecil
  status         String   @default("ACTIVE") // ACTIVE, INACTIVE
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  currency     Currency               @relation(fields: [currencyId], references: [id])
  custodian    User?                  @relation("PettyCashCustodian", fields: [custodianId], references: [id])
  transactions PettyCashTransaction[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([custodianId])
}

// Petty Cash Transaction Model
model PettyCashTransaction {
  id              String    @id @default(uuid())
  pettyCashId     String
  transactionType String // REPLENISH, DISBURSEMENT, ADJUSTMENT
  amount          Float
  description     String
  reference       String? // Nomor referensi
  accountId       String? // COA untuk pencatatan di sistem utama
  approvedBy      String? // User ID yang approve
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())

  pettyCash PettyCash @relation(fields: [pettyCashId], references: [id], onDelete: Cascade)

  @@index([pettyCashId])
  @@index([transactionType])
  @@index([createdAt])
}

// Work Order Model
model WorkOrder {
  id                     String    @id @default(uuid())
  organizationId         String
  productItemId          String?
  bomId                  String?
  code                   String // Kode WO (misal: WO-2024-001)
  barcode                String? // Barcode untuk scan
  title                  String // Judul/Deskripsi singkat
  description            String? // Deskripsi lengkap
  customerId             String? // Customer terkait
  status                 String    @default("DRAFT") // DRAFT, RELEASED, IN_PROGRESS, COMPLETED, CLOSED, CANCELLED
  priority               String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  assignedTo             String? // User ID yang ditugaskan
  startDate              DateTime?
  dueDate                DateTime?
  completedAt            DateTime?
  estimatedHours         Float?
  actualHours            Float?
  plannedQty             Float     @default(0)
  actualQty              Float     @default(0)
  plannedMaterialCost    Float     @default(0)
  plannedLaborCost       Float     @default(0)
  plannedOverheadCost    Float     @default(0)
  plannedMachineCost     Float     @default(0)
  plannedSubcontractCost Float     @default(0)
  plannedWasteValue      Float     @default(0)
  plannedTotalCost       Float     @default(0)
  actualMaterialCost     Float     @default(0)
  actualLaborCost        Float     @default(0)
  actualOverheadCost     Float     @default(0)
  actualMachineCost      Float     @default(0)
  actualSubcontractCost  Float     @default(0)
  actualWasteValue       Float     @default(0)
  actualTotalCost        Float     @default(0)
  hppPerUnit             Float     @default(0)
  varianceAmount         Float     @default(0)
  variancePercent        Float     @default(0)
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedUser   User?                    @relation("WorkOrderAssignee", fields: [assignedTo], references: [id])
  customer       Customer?                @relation(fields: [customerId], references: [id])
  productItem    InventoryItem?           @relation("WorkOrderProductItem", fields: [productItemId], references: [id], onDelete: SetNull)
  bom            BillOfMaterial?          @relation(fields: [bomId], references: [id], onDelete: SetNull)
  items          WorkOrderItem[]
  materialIssues WorkOrderMaterialIssue[]
  costEntries    WorkOrderCostEntry[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([status])
  @@index([assignedTo])
  @@index([barcode])
  @@index([productItemId])
  @@index([bomId])
}

// Work Order Item Model
model WorkOrderItem {
  id          String   @id @default(uuid())
  workOrderId String
  itemId      String? // Item dari inventory
  description String
  quantity    Float
  unit        String? // Satuan (pcs, kg, dll)
  unitPrice   Float    @default(0)
  totalPrice  Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())

  workOrder WorkOrder      @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  item      InventoryItem? @relation("WorkOrderItemInventory", fields: [itemId], references: [id], onDelete: SetNull)

  @@index([workOrderId])
  @@index([itemId])
}

// Warehouse Model (Multi-Warehouse)
model Warehouse {
  id             String   @id @default(uuid())
  organizationId String
  code           String // Kode gudang (misal: WH-01)
  name           String // Nama gudang
  location       String? // Alamat lokasi
  type           String   @default("MAIN") // MAIN, BRANCH, TRANSIT
  managerId      String? // User ID manager gudang
  status         String   @default("ACTIVE") // ACTIVE, INACTIVE
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  manager        User?           @relation("WarehouseManager", fields: [managerId], references: [id])
  inventoryItems InventoryItem[]
  stockOpnames   StockOpname[]
  branch         Branch?         @relation("BranchWarehouse")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([status])
}

// Inventory Item Model
model InventoryItem {
  id              String   @id @default(uuid())
  organizationId  String
  warehouseId     String
  code            String // Kode barang (SKU)
  barcode         String? // Barcode untuk scan
  name            String // Nama barang
  description     String?
  category        String? // Kategori barang
  itemType        String?  @default("GENERAL") // GENERAL, COIL, RAW_MATERIAL, FINISHED_GOOD, SEMI_FINISHED
  unit            String // Satuan dasar (pcs, kg, dll)
  secondaryUnit   String? // Satuan sekunder (dus, koli, dll)
  conversionRate  Float?   @default(1) // Konversi ke satuan sekunder (1 dus = X pcs)
  shelf           String? // Rak/shelf lokasi barang
  row             String? // Baris rak
  level           String? // Tingkat rak
  bin             String? // Bin/kompartemen
  valuationMethod String   @default("AVERAGE") // FIFO, LIFO, AVERAGE
  quantity        Float    @default(0) // Jumlah fisik saat ini
  minStock        Float    @default(0) // Minimum stock
  maxStock        Float? // Maximum stock
  reorderPoint    Float?   @default(0) // Titik reorder
  safetyStock     Float?   @default(0) // Safety stock
  unitCost        Float    @default(0) // Harga per unit (untuk penilaian stok)
  totalValue      Float    @default(0) // Total nilai stok (quantity * unitCost)
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization         Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse            Warehouse                @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  movements            InventoryMovement[]
  stockOpnames         StockOpnameItem[]
  salesOrderItems      SalesOrderItem[]
  deliveryOrderItems   DeliveryOrderItem[]
  bomAsProduct         BillOfMaterial[]         @relation("BomProductItem")
  bomAsComponent       BillOfMaterialLine[]     @relation("BomComponentItem")
  workOrderItems       WorkOrderItem[]          @relation("WorkOrderItemInventory")
  purchaseOrderItems   PurchaseOrderItem[]
  issuedToWorkOrders   WorkOrderMaterialIssue[] @relation("WorkOrderIssueInventory")
  producedByWorkOrders WorkOrder[]              @relation("WorkOrderProductItem")

  @@unique([organizationId, warehouseId, code])
  @@index([organizationId])
  @@index([warehouseId])
  @@index([barcode])
  @@index([category])
  @@index([itemType])
  @@index([shelf, row, level])
}

// Inventory Movement Model (Mutasi Stok)
model InventoryMovement {
  id              String   @id @default(uuid())
  organizationId  String
  itemId          String
  movementType    String // IN, OUT, ADJUSTMENT, TRANSFER
  quantity        Float
  unitCost        Float? // Harga per unit saat movement
  totalCost       Float? // Total cost (quantity * unitCost)
  reference       String? // Referensi transaksi (WO#, PO#, dll)
  description     String?
  fromWarehouseId String? // Untuk transfer
  toWarehouseId   String? // Untuk transfer
  performedBy     String? // User ID yang melakukan
  createdAt       DateTime @default(now())

  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item                    InventoryItem            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  workOrderMaterialIssues WorkOrderMaterialIssue[]

  @@index([organizationId])
  @@index([itemId])
  @@index([movementType])
  @@index([createdAt])
}

model BillOfMaterial {
  id             String   @id @default(uuid())
  organizationId String
  productItemId  String
  code           String
  name           String
  version        Int      @default(1)
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productItem  InventoryItem        @relation("BomProductItem", fields: [productItemId], references: [id], onDelete: Cascade)
  lines        BillOfMaterialLine[]
  workOrders   WorkOrder[]

  @@unique([organizationId, code, version])
  @@index([organizationId])
  @@index([productItemId])
  @@index([isActive])
}

model BillOfMaterialLine {
  id              String   @id @default(uuid())
  bomId           String
  componentItemId String
  quantityPerUnit Float
  uom             String?
  scrapPercent    Float    @default(0)
  sequence        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bom           BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentItem InventoryItem  @relation("BomComponentItem", fields: [componentItemId], references: [id], onDelete: Cascade)

  @@index([bomId])
  @@index([componentItemId])
  @@index([sequence])
}

model WorkOrderMaterialIssue {
  id          String   @id @default(uuid())
  workOrderId String
  itemId      String
  plannedQty  Float    @default(0)
  issuedQty   Float    @default(0)
  unitCost    Float    @default(0)
  totalCost   Float    @default(0)
  movementId  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workOrder WorkOrder          @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  item      InventoryItem      @relation("WorkOrderIssueInventory", fields: [itemId], references: [id], onDelete: Cascade)
  movement  InventoryMovement? @relation(fields: [movementId], references: [id], onDelete: SetNull)

  @@index([workOrderId])
  @@index([itemId])
  @@index([movementId])
}

model WorkOrderCostEntry {
  id          String            @id @default(uuid())
  workOrderId String
  costType    WorkOrderCostType
  amount      Float
  reference   String?
  description String?
  entryDate   DateTime          @default(now())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([costType])
  @@index([entryDate])
}

// Stock Opname Model
model StockOpname {
  id             String    @id @default(uuid())
  organizationId String
  warehouseId    String
  code           String // Kode stock opname (misal: SO-2024-001)
  opnameDate     DateTime  @default(now())
  status         String    @default("DRAFT") // DRAFT, IN_PROGRESS, PENDING_APPROVAL, APPROVED, REJECTED, COMPLETED, CANCELLED
  performedBy    String? // User ID yang melakukan check fisik
  approvedBy     String? // User ID yang approve
  approvedAt     DateTime? // Waktu approval
  syncedAt       DateTime? // Waktu sync ke sistem
  isSynced       Boolean   @default(false) // Status sync
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse         @relation(fields: [warehouseId], references: [id])
  performer    User?             @relation("StockOpnamePerformer", fields: [performedBy], references: [id])
  approver     User?             @relation("StockOpnameApprover", fields: [approvedBy], references: [id])
  items        StockOpnameItem[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([warehouseId])
  @@index([opnameDate])
  @@index([status])
  @@index([performedBy])
  @@index([approvedBy])
}

// Stock Opname Item Model
model StockOpnameItem {
  id               String   @id @default(uuid())
  stockOpnameId    String
  itemId           String
  systemQuantity   Float // Jumlah di sistem
  physicalQuantity Float // Jumlah fisik
  difference       Float // Selisih (physical - system)
  unitCost         Float? // Harga per unit
  totalDifference  Float? // Total nilai selisih
  notes            String?
  createdAt        DateTime @default(now())

  stockOpname StockOpname   @relation(fields: [stockOpnameId], references: [id], onDelete: Cascade)
  item        InventoryItem @relation(fields: [itemId], references: [id])

  @@index([stockOpnameId])
  @@index([itemId])
}

// ============================================
// SALES & MARKETING MODULE
// ============================================

// Sales Order Model
model SalesOrder {
  id             String    @id @default(uuid())
  organizationId String
  code           String // SO-2024-0001
  customerId     String
  salesPersonId  String? // User ID sales person
  orderDate      DateTime  @default(now())
  deliveryDate   DateTime?
  status         String    @default("DRAFT") // DRAFT, CONFIRMED, PROCESSING, SHIPPED, DELIVERED, CANCELLED
  priority       String    @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  subtotal       Float     @default(0)
  discountAmount Float     @default(0)
  taxAmount      Float     @default(0)
  totalAmount    Float     @default(0)
  notes          String?
  terms          String? // Terms & conditions
  internalNotes  String? // Catatan internal
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer         @relation(fields: [customerId], references: [id])
  salesPerson    User?            @relation("SalesPerson", fields: [salesPersonId], references: [id])
  items          SalesOrderItem[]
  deliveryOrders DeliveryOrder[]
  commission     SalesCommission?

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@index([customerId])
  @@index([salesPersonId])
  @@index([orderDate])
}

// Sales Order Item
model SalesOrderItem {
  id              String   @id @default(uuid())
  salesOrderId    String
  itemId          String // InventoryItem ID
  quantity        Float    @default(0)
  unitPrice       Float    @default(0)
  discountPercent Float    @default(0)
  discountAmount  Float    @default(0)
  taxPercent      Float    @default(0)
  taxAmount       Float    @default(0)
  totalPrice      Float    @default(0)
  notes           String?
  deliveredQty    Float    @default(0) // Qty yang sudah di-DO
  createdAt       DateTime @default(now())

  salesOrder    SalesOrder          @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  item          InventoryItem       @relation(fields: [itemId], references: [id])
  deliveryItems DeliveryOrderItem[]

  @@index([salesOrderId])
  @@index([itemId])
}

// Delivery Order Model
model DeliveryOrder {
  id              String    @id @default(uuid())
  organizationId  String
  code            String // DO-2024-0001
  salesOrderId    String // Referensi ke SalesOrder
  customerId      String
  deliveryDate    DateTime  @default(now())
  status          String    @default("DRAFT") // DRAFT, READY, SHIPPED, DELIVERED, RETURNED, CANCELLED
  driverName      String?
  driverPhone     String?
  vehiclePlate    String? // Nomor plat kendaraan
  deliveryAddress String?
  notes           String?
  trackingNumber  String? // Nomor resi pengiriman
  shippedAt       DateTime?
  deliveredAt     DateTime?
  receivedBy      String? // Nama penerima
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesOrder   SalesOrder          @relation(fields: [salesOrderId], references: [id])
  customer     Customer            @relation(fields: [customerId], references: [id])
  items        DeliveryOrderItem[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@index([salesOrderId])
  @@index([customerId])
}

// Delivery Order Item
model DeliveryOrderItem {
  id               String   @id @default(uuid())
  deliveryOrderId  String
  salesOrderItemId String
  itemId           String
  quantity         Float    @default(0)
  notes            String?
  createdAt        DateTime @default(now())

  deliveryOrder  DeliveryOrder  @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  salesOrderItem SalesOrderItem @relation(fields: [salesOrderItemId], references: [id])
  item           InventoryItem  @relation(fields: [itemId], references: [id])

  @@index([deliveryOrderId])
  @@index([salesOrderItemId])
  @@index([itemId])
}

// Sales Commission Model
model SalesCommission {
  id               String    @id @default(uuid())
  organizationId   String
  salesOrderId     String    @unique // 1 commission per sales order
  salesPersonId    String
  baseAmount       Float     @default(0) // Total penjualan
  commissionRate   Float     @default(0) // Persentase komisi (e.g., 5% = 0.05)
  commissionAmount Float     @default(0) // Nilai komisi
  bonusAmount      Float     @default(0) // Bonus tambahan
  totalCommission  Float     @default(0) // Total komisi + bonus
  status           String    @default("PENDING") // PENDING, APPROVED, PAID, CANCELLED
  approvedBy       String?
  approvedAt       DateTime?
  paidAt           DateTime?
  paymentRef       String? // Referensi pembayaran
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesOrder   SalesOrder   @relation(fields: [salesOrderId], references: [id])
  salesPerson  User         @relation("CommissionSalesPerson", fields: [salesPersonId], references: [id])

  @@index([organizationId, status])
  @@index([salesPersonId])
  @@index([createdAt])
}

// Branch/Cabang Model
model Branch {
  id             String   @id @default(uuid())
  organizationId String
  code           String // Kode cabang (misal: CAB-001)
  name           String // Nama cabang
  address        String? // Alamat lengkap
  city           String? // Kota
  province       String? // Provinsi
  postalCode     String? // Kode pos
  country        String?  @default("Indonesia")
  phone          String? // Nomor telepon
  email          String? // Email
  managerId      String? // User ID manager cabang
  warehouseId    String?  @unique // Warehouse ID yang terhubung ke cabang
  status         String   @default("ACTIVE") // ACTIVE, INACTIVE
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  manager      User?        @relation("BranchManager", fields: [managerId], references: [id])
  warehouse    Warehouse?   @relation("BranchWarehouse", fields: [warehouseId], references: [id])

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([status])
  @@index([managerId])
}

// Budget Model (Anggaran)
model Budget {
  id              String    @id @default(uuid())
  organizationId  String
  year            Int // Tahun anggaran
  divisionId      String? // Divisi/Departemen
  code            String // Kode budget (misal: BUD-2024-001)
  name            String // Nama budget
  periodType      String    @default("ANNUAL") // ANNUAL, QUARTERLY, MONTHLY
  status          String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED, ACTIVE, CLOSED
  totalBudget     Float     @default(0) // Total budget
  totalActual     Float     @default(0) // Total actual
  variance        Float     @default(0) // Selisih (actual - budget)
  variancePercent Float     @default(0) // Persentase selisih
  approvedBy      String? // User ID yang approve
  approvedAt      DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  division     Division?      @relation(fields: [divisionId], references: [id])
  approver     User?          @relation("BudgetApprover", fields: [approvedBy], references: [id])
  items        BudgetItem[]
  actuals      BudgetActual[]

  @@unique([organizationId, code])
  @@unique([organizationId, year, divisionId])
  @@index([organizationId])
  @@index([year])
  @@index([divisionId])
  @@index([status])
}

// Budget Item Model (Detail Anggaran)
model BudgetItem {
  id              String   @id @default(uuid())
  budgetId        String
  accountId       String? // Akun COA
  category        String? // Kategori pengeluaran/pemasukan
  itemName        String // Nama item budget
  budgetAmount    Float    @default(0) // Jumlah budget
  actualAmount    Float    @default(0) // Jumlah actual
  variance        Float    @default(0) // Selisih
  variancePercent Float    @default(0) // Persentase selisih
  q1Budget        Float    @default(0) // Budget Q1
  q1Actual        Float    @default(0) // Actual Q1
  q2Budget        Float    @default(0) // Budget Q2
  q2Actual        Float    @default(0) // Actual Q2
  q3Budget        Float    @default(0) // Budget Q3
  q3Actual        Float    @default(0) // Actual Q3
  q4Budget        Float    @default(0) // Budget Q4
  q4Actual        Float    @default(0) // Actual Q4
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budget  Budget          @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  account ChartOfAccount? @relation("BudgetItemAccount", fields: [accountId], references: [id])
  actuals BudgetActual[]

  @@index([budgetId])
  @@index([accountId])
  @@index([category])
}

// Budget Actual Model (Actual vs Budget Tracking)
model BudgetActual {
  id              String   @id @default(uuid())
  budgetId        String
  budgetItemId    String?
  transactionId   String? // Referensi ke transaksi
  period          String // Period (Q1, Q2, Q3, Q4, atau bulan)
  actualAmount    Float    @default(0) // Jumlah actual
  budgetAmount    Float    @default(0) // Jumlah budget untuk period ini
  variance        Float    @default(0) // Selisih
  variancePercent Float    @default(0) // Persentase selisih
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budget     Budget      @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  budgetItem BudgetItem? @relation(fields: [budgetItemId], references: [id])

  @@index([budgetId])
  @@index([budgetItemId])
  @@index([period])
  @@index([transactionId])
}

// Division/Departemen Model (Multi-Division Management)
model Division {
  id             String   @id @default(uuid())
  organizationId String
  code           String // Kode divisi (misal: DIV-001)
  name           String // Nama divisi
  parentId       String? // Parent division untuk hierarchy
  managerId      String?  @unique // User ID manager divisi
  description    String?
  status         String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Division?    @relation("DivisionHierarchy", fields: [parentId], references: [id])
  children     Division[]   @relation("DivisionHierarchy")
  manager      User?        @relation("DivisionManager", fields: [managerId], references: [id])
  budgets      Budget[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([parentId])
  @@index([managerId])
  @@index([status])
}

model InventoryAccountingConfig {
  id                         String   @id @default(uuid())
  organizationId             String   @unique
  inventoryAccountId         String?
  wipAccountId               String?
  finishedGoodsAccountId     String?
  inventoryVarianceAccountId String?
  cogsAccountId              String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  organization               Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryAccount           ChartOfAccount?  @relation("ConfigInventoryAccount", fields: [inventoryAccountId], references: [id])
  wipAccount                 ChartOfAccount?  @relation("ConfigWipAccount", fields: [wipAccountId], references: [id])
  finishedGoodsAccount       ChartOfAccount?  @relation("ConfigFinishedGoodsAccount", fields: [finishedGoodsAccountId], references: [id])
  inventoryVarianceAccount   ChartOfAccount?  @relation("ConfigVarianceAccount", fields: [inventoryVarianceAccountId], references: [id])
  cogsAccount                ChartOfAccount?  @relation("ConfigCogsAccount", fields: [cogsAccountId], references: [id])
}
