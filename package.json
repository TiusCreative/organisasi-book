{
  "name": "organisasi-book",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "vercel-build": "prisma generate && next build --webpack",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "seed": "tsx prisma/seed.ts",
    "seed:dummy": "tsx prisma/seed-dummy.ts",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:storybook": "vitest run --project storybook",
    "test:watch": "vitest --project unit",
    "ops:daily": "tsx scripts/run-daily-warehouse-ops.ts",
    "ops:outbox:purge": "tsx scripts/purge-outbox.ts",
    "ops:audit:purge": "tsx scripts/purge-audit-logs.ts",
    "depreciation:monthly": "tsx scripts/run-monthly-depreciation.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.474.0",
    "next": "^16.2.4",
    "next-pwa": "^5.6.0",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-to-print": "^3.0.5"
  },
  "devDependencies": {
    "@prisma/config": "^7.7.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^16.4.5",
    "eslint": "^8",
    "eslint-config-next": "15.0.3",
    "postcss": "^8",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "storybook": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@chromatic-com/storybook": "^5.1.2",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "vite": "^8.0.10",
    "eslint-plugin-storybook": "^10.3.5",
    "vitest": "^4.1.5",
    "playwright": "^1.59.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
